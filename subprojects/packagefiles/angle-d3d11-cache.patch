# Fixes a crash that can happen when using ANGLE's Direct3D 11 backend.
# This patch is copied from <https://issues.angleproject.org/issues/507897058>.

--- a/src/libANGLE/renderer/d3d/d3d11/InputLayoutCache.cpp
+++ b/src/libANGLE/renderer/d3d/d3d11/InputLayoutCache.cpp
@@ -66,7 +66,8 @@ struct PackedAttribute
 
 }  // anonymous namespace
 
-PackedAttributeLayout::PackedAttributeLayout() : numAttributes(0), attributeData({}) {}
+PackedAttributeLayout::PackedAttributeLayout()
+    : numAttributes(0), unusedPadding(0), attributeData({}) {}
 
 PackedAttributeLayout::PackedAttributeLayout(const PackedAttributeLayout &other) = default;
 
--- a/src/libANGLE/renderer/d3d/d3d11/InputLayoutCache.h
+++ b/src/libANGLE/renderer/d3d/d3d11/InputLayoutCache.h
@@ -41,6 +41,7 @@ struct PackedAttributeLayout
     bool operator==(const PackedAttributeLayout &other) const;
 
     uint32_t numAttributes;
+    uint32_t unusedPadding;
     gl::AttribArray<uint64_t> attributeData;
 };
 }  // namespace rx
